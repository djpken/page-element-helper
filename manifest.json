{
  "manifest_version": 3,
  "name": "Codex Page Element Helper",
  "version": "1.0.0",
  "description": "Hover a page element and copy an AI-ready description (Codex or Claude Code): selector, aria-label, text, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "clipboardWrite", "contextMenus", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-picker": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "MacCtrl+Shift+E"
      },
      "description": "Toggle Codex element picker"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
